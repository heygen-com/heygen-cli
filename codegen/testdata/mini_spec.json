{
  "openapi": "3.0.0",
  "info": {
    "title": "Mini Test API",
    "version": "1.0.0"
  },
  "paths": {
    "/v3/widgets": {
      "get": {
        "tags": ["Widgets"],
        "summary": "List widgets",
        "operationId": "listWidgets",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 10
            },
            "description": "Max results per page"
          },
          {
            "name": "token",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Pagination token"
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["active", "archived"]
            },
            "description": "Filter by status"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "has_more": {
                      "type": "boolean"
                    },
                    "next_token": {
                      "type": ["string", "null"]
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Widgets"],
        "summary": "Create a widget",
        "operationId": "createWidget",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWidgetRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Widget"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v3/widgets/{widget_id}": {
      "get": {
        "tags": ["Widgets"],
        "summary": "Get widget details",
        "operationId": "getWidget",
        "parameters": [
          {
            "name": "widget_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Widget ID"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Widget"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Widgets"],
        "summary": "Delete a widget",
        "operationId": "deleteWidget",
        "parameters": [
          {
            "name": "widget_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Widget ID"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v3/widgets/{widget_id}/activate": {
      "post": {
        "tags": ["Widgets"],
        "summary": "Activate a widget",
        "operationId": "activateWidget",
        "parameters": [
          {
            "name": "widget_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Widget ID"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ActivateWidgetRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v3/uploads": {
      "post": {
        "tags": ["Uploads"],
        "summary": "Upload a file",
        "operationId": "uploadFile",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "File to upload"
                  }
                },
                "required": ["file"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/legacy": {
      "get": {
        "tags": ["Legacy"],
        "summary": "Legacy endpoint (should be skipped)",
        "operationId": "legacyGet",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Widget": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "status": {"type": "string"}
        }
      },
      "CreateWidgetRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Widget name"
          },
          "color": {
            "anyOf": [
              {"type": "string"},
              {"type": "null"}
            ],
            "default": null,
            "description": "Widget color"
          },
          "count": {
            "type": "integer",
            "description": "Widget count",
            "minimum": 1,
            "maximum": 100
          },
          "tags": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Widget tags"
          },
          "settings": {
            "type": "object",
            "description": "Complex settings object",
            "properties": {
              "nested": {"type": "string"}
            }
          }
        },
        "required": ["name"]
      },
      "ActivateWidgetRequest": {
        "type": "object",
        "properties": {
          "force": {
            "type": "boolean",
            "description": "Force activation",
            "default": false
          }
        }
      }
    }
  }
}
